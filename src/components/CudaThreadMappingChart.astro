---
const GRID_X = 3;
const GRID_Y = 2;
const THREAD_X = 3;
const THREAD_Y = 3;

const blocks = Array.from({ length: GRID_X * GRID_Y }, (_, bLinear) => {
  const by = Math.floor(bLinear / GRID_X);
  const bx = bLinear % GRID_X;

  const threads = Array.from({ length: THREAD_X * THREAD_Y }, (_, tLinear) => {
    const ty = Math.floor(tLinear / THREAD_X);
    const tx = tLinear % THREAD_X;
    const gLinear = bLinear * THREAD_X * THREAD_Y + tLinear;
    return { tx, ty, tLinear, gLinear };
  });

  return { bx, by, bLinear, threads };
});
---

  <figure class="my-8 rounded-2xl border border-border/60 bg-muted/20 p-4">
    <div class="cuda-viz">
    <div class="cuda-grid-title">Grid (2D)</div>
    <div class="cuda-grid-note">
      Each thread is identified by its block coordinates and its local coordinates inside that block.
    </div>

    <div class="cuda-grid-box" style={`--grid-x:${GRID_X};`}>
      {blocks.map((block) => (
        <section class="cuda-block" aria-label={`block (${block.bx}, ${block.by})`}>
          <header class="cuda-block-title">
            <span>block ({block.bx}, {block.by})</span>
            <span class="cuda-linear">b{block.bLinear}</span>
          </header>

          <div class="cuda-thread-grid" style={`--thread-x:${THREAD_X};`}>
            {block.threads.map((thread) => (
              <div
                class="cuda-thread"
                title={`thread (${thread.tx}, ${thread.ty}) inside block (${block.bx}, ${block.by}), local t${thread.tLinear}`}
              >
                <span>t{thread.tLinear}</span>
                <small>({thread.tx},{thread.ty})</small>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>

  <figcaption class="mt-3 text-sm text-muted-foreground">
    The kernel uses <code>blockIdx</code> and <code>threadIdx</code> to compute one output coordinate <code>(row, col)</code> per thread.
  </figcaption>
</figure>

<style>
  .cuda-viz {
    border: 1px solid rgba(148, 163, 184, 0.5);
    border-radius: 14px;
    padding: 12px;
    background: linear-gradient(145deg, rgba(248, 250, 252, 0.9), rgba(226, 232, 240, 0.35));
  }

  .cuda-grid-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0f172a;
  }

  .cuda-grid-note {
    margin-top: 2px;
    font-size: 0.78rem;
    color: #334155;
  }

  .cuda-grid-box {
    margin-top: 10px;
    border: 2px solid #475569;
    border-radius: 12px;
    padding: 10px;
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(var(--grid-x), minmax(0, 1fr));
    background: rgba(255, 255, 255, 0.7);
  }

  .cuda-block {
    border: 1px solid #64748b;
    border-radius: 10px;
    background: #f8fafc;
    padding: 8px;
    min-width: 0;
  }

  .cuda-block-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    font-weight: 700;
    color: #1e293b;
  }

  .cuda-linear {
    border: 1px solid #cbd5e1;
    border-radius: 999px;
    padding: 1px 7px;
    background: #ffffff;
    font-weight: 600;
  }

  .cuda-thread-grid {
    margin-top: 7px;
    display: grid;
    gap: 4px;
    grid-template-columns: repeat(var(--thread-x), minmax(0, 1fr));
  }

  .cuda-thread {
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    background: #ffffff;
    padding: 4px 2px;
    text-align: center;
    line-height: 1.1;
  }

  .cuda-thread span {
    display: block;
    font-size: 0.69rem;
    font-weight: 700;
    color: #0f172a;
  }

  .cuda-thread small {
    font-size: 0.61rem;
    color: #475569;
  }

  @media (max-width: 900px) {
    .cuda-grid-box {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .cuda-grid-box {
      grid-template-columns: repeat(1, minmax(0, 1fr));
    }
  }
</style>
