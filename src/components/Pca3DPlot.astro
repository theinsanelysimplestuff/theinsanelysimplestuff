---
interface Props {
  view?: "3d" | "2d" | "both";
}

const { view = "both" } = Astro.props;

const show3d = view === "3d" || view === "both";
const show2d = view === "2d" || view === "both";

const plot3dId = "pca-3d-plot";
const plot2dId = "pca-2d-plot";
---

<figure class="my-10 rounded-2xl border border-border/60 bg-muted/20 p-4">
  <div class="space-y-6">
    {show3d && (
      <div>
        <h3 class="mb-3 text-center text-base font-semibold not-italic text-foreground">Original 3D Data</h3>
        <div id={plot3dId} class="h-[440px] w-full"></div>
      </div>
    )}
    {show2d && (
      <div>
        <h3 class="mb-3 text-center text-base font-semibold not-italic text-foreground">2D PCA Projection</h3>
        <div id={plot2dId} class="h-[440px] w-full"></div>
      </div>
    )}
  </div>
  <figcaption class="mt-3 text-sm text-muted-foreground">
    {show3d && show2d && (
      <>
        Top: 3D data with PC3 noise direction.<br />
        Bottom: 2D PCA projection on the principal plane.
      </>
    )}
    {show3d && !show2d && "3D data with PC3 noise direction."}
    {show2d && !show3d && "2D PCA projection on the principal plane."}
  </figcaption>
</figure>

<script>
  import Plotly from "plotly.js-dist-min";

  const root3d = document.getElementById("pca-3d-plot");
  const root2d = document.getElementById("pca-2d-plot");

  if (root3d || root2d) {
    type Point = [number, number, number];
    type Point2D = [number, number];

    const points: Point[] = [];

    for (let i = 0; i < 140; i += 1) {
      const angle = i * 0.28;
      const radius = 1.6 + 0.5 * Math.sin(i * 0.17);
      const ridge = Math.sin(angle * 1.2) * 0.35;

      const x = radius * Math.cos(angle) + 0.12 * Math.sin(i * 0.51);
      const y = 0.7 * radius * Math.sin(angle) + 0.14 * Math.cos(i * 0.37);
      const z = 0.2 * x - 0.12 * y + ridge + 0.18 * Math.sin(i * 0.93);

      points.push([x, y, z]);
    }

    const xs: number[] = points.map(point => point[0]);
    const ys: number[] = points.map(point => point[1]);
    const zs: number[] = points.map(point => point[2]);

    const center: Point = [
      xs.reduce((sum, value) => sum + value, 0) / xs.length,
      ys.reduce((sum, value) => sum + value, 0) / ys.length,
      zs.reduce((sum, value) => sum + value, 0) / zs.length,
    ];

    const principalDirection: Point = [1.3, 0.85, 0.05];
    const secondaryDirection: Point = [-0.7, 1.1, 0.08];
    const tertiaryDirection: Point = [0.1, -0.15, 0.95];

    const normalize = (vector: Point): Point => {
      const length = Math.hypot(...vector);
      return vector.map(value => value / length) as Point;
    };

    const scale = (vector: Point, factor: number): Point =>
      vector.map(value => value * factor) as Point;
    const add = (a: Point, b: Point): Point =>
      a.map((value, index) => value + b[index]) as Point;
    const subtract = (a: Point, b: Point): Point =>
      a.map((value, index) => value - b[index]) as Point;
    const dot = (a: Point, b: Point): number =>
      a.reduce((sum, value, index) => sum + value * b[index], 0);

    const axisTrace = (vector: Point, color: string, label: string, basePoint: Point = [0, 0, 0]) => {
      const direction = scale(normalize(vector), 2.8);
      const start = add(basePoint, scale(direction, -1));
      const end = add(basePoint, direction);

      return {
        type: "scatter3d",
        mode: "lines+text",
        x: [start[0], end[0]],
        y: [start[1], end[1]],
        z: [start[2], end[2]],
        line: { color, width: 8 },
        marker: { size: 0 },
        text: ["", label],
        textposition: "top center",
        showlegend: false,
        hoverinfo: "skip",
      };
    };

    // 3D Plot - Original data (not origin-centered)
    const data3d = [
      {
        type: "scatter3d",
        mode: "markers",
        x: xs,
        y: ys,
        z: zs,
        marker: {
          size: 4,
          color: xs,
          colorscale: "Viridis",
          opacity: 0.9,
        },
        hovertemplate: "x=%{x:.2f}<br>y=%{y:.2f}<br>z=%{z:.2f}<extra></extra>",
      },
      axisTrace(principalDirection, "#ef4444", "PC1 (Primary)", center),
      axisTrace(secondaryDirection, "#22c55e", "PC2 (Secondary)", center),
      axisTrace(tertiaryDirection, "#3b82f6", "PC3 (Noise)", center),
    ];

    const layout3d = {
      margin: { l: 0, r: 0, t: 0, b: 0 },
      paper_bgcolor: "transparent",
      plot_bgcolor: "transparent",
      showlegend: false,
      legend: { orientation: "h", y: -0.08 },
      scene: {
        aspectmode: "cube",
        xaxis: { title: "x₁", backgroundcolor: "rgba(0,0,0,0)", gridcolor: "rgba(148,163,184,0.2)", zerolinecolor: "rgba(148,163,184,0.3)" },
        yaxis: { title: "x₂", backgroundcolor: "rgba(0,0,0,0)", gridcolor: "rgba(148,163,184,0.2)", zerolinecolor: "rgba(148,163,184,0.3)" },
        zaxis: { title: "x₃", backgroundcolor: "rgba(0,0,0,0)", gridcolor: "rgba(148,163,184,0.2)", zerolinecolor: "rgba(148,163,184,0.3)" },
      },
    };

    // 2D Plot - PCA projection (origin-centered)
    const normPC1 = normalize(principalDirection);
    const normPC2 = normalize(secondaryDirection);

    const projections2d: Point2D[] = points.map(point => [
      dot(subtract(point, center), normPC1),
      dot(subtract(point, center), normPC2),
    ]);

    const proj2d_xs = projections2d.map(p => p[0]);
    const proj2d_ys = projections2d.map(p => p[1]);

    // Create transparent plane surface
    const planeSize = 3.5;
    const planeX = [-planeSize, planeSize, planeSize, -planeSize, -planeSize];
    const planeY = [-planeSize, -planeSize, planeSize, planeSize, -planeSize];
    const planeZ = [0, 0, 0, 0, 0];

    const data2d = [
      {
        type: "surface",
        x: [-planeSize, planeSize],
        y: [-planeSize, planeSize],
        z: [[0, 0], [0, 0]],
        opacity: 0.15,
        colorscale: "Greys",
        showscale: false,
        showlegend: false,
        hoverinfo: "skip",
      },
      {
        type: "scatter3d",
        mode: "markers",
        x: proj2d_xs,
        y: proj2d_ys,
        z: proj2d_xs.map(() => 0),
        marker: {
          size: 5,
          color: proj2d_xs,
          colorscale: "RdYlBu",
          opacity: 0.85,
          showscale: true,
          colorbar: {
            title: "PC1",
            thickness: 15,
            len: 0.7,
          },
        },
        showlegend: false,
        hovertemplate: "PC1=%{x:.2f}<br>PC2=%{y:.2f}<extra></extra>",
      },
      {
        type: "scatter3d",
        mode: "lines",
        x: planeX,
        y: planeY,
        z: planeZ,
        line: { color: "rgba(148,163,184,0.3)", width: 2 },
        name: "Plane boundary",
        hoverinfo: "skip",
        showlegend: false,
      },
    ];

    const layout2d = {
      margin: { l: 0, r: 0, t: 0, b: 0 },
      paper_bgcolor: "transparent",
      plot_bgcolor: "transparent",
      showlegend: false,
      legend: { orientation: "h", y: -0.08 },
      scene: {
        aspectmode: "cube",
        xaxis: { title: "PC1", backgroundcolor: "rgba(0,0,0,0)", gridcolor: "rgba(148,163,184,0.2)", zerolinecolor: "rgba(148,163,184,0.5)" },
        yaxis: { title: "PC2", backgroundcolor: "rgba(0,0,0,0)", gridcolor: "rgba(148,163,184,0.2)", zerolinecolor: "rgba(148,163,184,0.5)" },
        zaxis: { title: "", backgroundcolor: "rgba(0,0,0,0)", gridcolor: "rgba(0,0,0,0)", zerolinecolor: "rgba(148,163,184,0.5)" },
      },
    };

    if (root3d) {
      Plotly.newPlot(root3d, data3d, layout3d, {
        responsive: true,
        displaylogo: false,
      });
    }

    if (root2d) {
      Plotly.newPlot(root2d, data2d, layout2d, {
        responsive: true,
        displaylogo: false,
      });
    }
  }
</script>